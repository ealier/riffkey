# === Публичный URL сайта (обязательно на Render) ===
# После деплоя: https://ИМЯ-СЕРВИСА.onrender.com (без / в конце)
PUBLIC_URL=https://riffkey.onrender.com

# === ЮKassa (тестовые ключи для диплома) ===
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=test_your_secret_key

# === MySQL — локально (XAMPP) ===
# Запустите MySQL в XAMPP, импортируйте database/schema.sql в phpMyAdmin
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=riffkey

# === MySQL — Render (бесплатно, БД отдельно от Render) ===
# На Render бесплатно есть только PostgreSQL. MySQL возьмите бесплатно здесь:
#   • https://db4free.net — регистрация → phpMyAdmin → импорт database/schema-cloud.sql
#   • https://tidbcloud.com — Serverless (MySQL-совместимый), free tier
# В Render → Environment задайте DB_* из письма/панели провайдера:
# DB_HOST=db4free.net
# DB_PORT=3306
# DB_USER=your_user
# DB_PASSWORD=your_password
# DB_NAME=your_db_name
# DB_SSL=false          ← для db4free; для TiDB Cloud: DB_SSL=true

# === Как это устроено ===
# В .env задаётся ОДИН почтовый ящик сервера — он только ОТПРАВЛЯЕТ письма (как «почтальон» сайта).
# Пользователь при регистрации вводит ЛЮБОЙ свой email — код уходит именно туда:
# @mail.ru, @gmail.com, @internet.ru, @yandex.ru и т.д. Ограничений по домену в коде нет.
# У Gmail адрес заканчивается на @gmail.com (не gmail.ru).

# --- Вариант A: отправка через Mail.ru / internet.ru / bk.ru / list.ru (одна экосистема) ---
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=you@internet.ru
SMTP_PASS=your_app_password

# --- Вариант B: отправка через Google (если хотите слать с Gmail) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=пароль_приложения_Google_в_аккаунте_Google

# Пароль в SMTP_PASS — всегда «пароль приложения», не пароль от входа в браузер.
# Mail.ru: https://help.mail.ru/mail/security/protection/external

# Необязательно: поле «От» в письме
# SMTP_FROM=YANKI <you@internet.ru>

# === SMS подтверждение регистрации ===
# Поддерживаемый провайдер сейчас: smsru
SMS_PROVIDER=smsru
SMSRU_API_ID=your_smsru_api_id

# Настройки кода подтверждения
REGISTER_CODE_TTL_SECONDS=600
REGISTER_CODE_RESEND_COOLDOWN_SECONDS=60
REGISTER_CODE_MAX_ATTEMPTS=5
